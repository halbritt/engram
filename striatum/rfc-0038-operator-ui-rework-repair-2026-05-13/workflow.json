      },
      "expected_artifacts": [
        {"logical_name": "repair_interview_handoff", "kind": "handoff", "path": "docs/reviews/rfc0038-operator-ui-rework-2026-05-13/REPAIR_INTERVIEW_HANDOFF.md", "required": true}
      ]
