        {"path": "docs/reviews/rfc0038-operator-ui-rework-2026-05-13/REVIEW_correctness_codex.md", "kind": "review"},
        {"path": "docs/reviews/rfc0038-operator-ui-rework-2026-05-13/REVIEW_ergonomics_claude.md", "kind": "review"},
        {"path": "src/engram/bench_review", "kind": "surface"}
