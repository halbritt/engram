        "mode": "repo_write",
        "repo_write": true,
        "allowed_paths": [
          "src/engram/bench_review/",
          "tests/test_bench_review.py",
          "docs/reviews/rfc0038-operator-ui-rework-2026-05-13/REPAIR_BENCH_HANDOFF.md"
