        },
        {
          "path": "docs/rfcs/0011-phase-3-claims-beliefs.md",
          "kind": "upstream_rfc"
        },
        {
          "path": "docs/rfcs/0017-extraction-prompt-versioning.md",
          "kind": "upstream_rfc"
        },
        {
          "path": "docs/rfcs/0018-evidence-to-claim-audit-cascade.md",
          "kind": "upstream_rfc"
        },
        {
          "path": "migrations/006_claims_beliefs.sql",
          "kind": "schema_baseline"
        },
        {
          "path": "migrations/007_claim_audits.sql",
          "kind": "schema_baseline"
        },
        {
          "path": "HUMAN_REQUIREMENTS.md",
          "kind": "principles"
        },
        {
          "path": "DECISION_LOG.md",
          "kind": "decision_log"
        }
      ],
      "write_scope": {
        "mode": "review_only_artifact",
        "repo_write": false,
        "allowed_paths": [
          "docs/reviews/rfc0021/"
        ],
        "forbidden_paths": [
          ".striatum/",
          "docs/rfcs/",
          "BUILD_PHASES.md",
          "DECISION_LOG.md",
          "HUMAN_REQUIREMENTS.md",
          "Makefile",
          "src/engram/",
          "migrations/"
        ]
      },
      "expected_artifacts": [
        {
          "logical_name": "review",
          "kind": "finding",
          "path": "docs/reviews/rfc0021/RFC_0021_GOLD_SET_REVIEW_claude.md",
          "required": true
