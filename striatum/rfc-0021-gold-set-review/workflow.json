{
  "schema_version": "striatum.workflow.v1",
  "workflow_id": "rfc-0021-gold-set-review",
  "workflow_version": "2026-05-08+initial",
  "name": "Engram RFC 0021 Gold-Set Interview Curation Multi-Agent Review",
  "branch": {
    "mode": "confirm",
    "suggested_name": "engram/rfc0021-gold-set-review",
    "allow_dirty": true
  },
  "coordinator": {
    "role_id": "coordinator",
    "lane_id": "codex"
  },
  "review_revision_policy": {
    "root_review_needs_revision": "human_checkpoint",
    "description": "Root-review needs_revision verdicts surface as human checkpoints; downstream ledger, synthesis, and final-review jobs remain blocked until the owner revises the RFC or records an override."
  },
  "lanes": {
    "codex": {
      "adapter": "process",
      "display_model": "Codex GPT-5.5",
      "command": [
        "codex",
        "exec",
        "--model",
        "gpt-5.5",
        "-"
      ],
      "capabilities": [
        "review",
        "write",
        "synthesis"
      ],
      "constraints": {
        "network": "forbidden",
        "transcripts": "off",
        "repo_scope": "local_only"
      }
    },
    "gemini": {
      "adapter": "process",
      "display_model": "Gemini 3.1 Pro Preview",
      "command": [
        "gemini",
        "--model",
        "gemini-3.1-pro-preview"
      ],
      "capabilities": [
        "review"
      ],
      "constraints": {
        "network": "forbidden",
        "transcripts": "off",
        "repo_scope": "local_only"
      }
    },
    "claude": {
      "adapter": "process",
      "display_model": "Claude Opus",
      "command": [
        "claude",
        "--model",
        "opus",
        "-p"
      ],
      "capabilities": [
        "review",
        "synthesis"
      ],
      "constraints": {
        "network": "forbidden",
        "transcripts": "off",
        "repo_scope": "local_only"
      }
    }
  },
  "roles": {
    "reviewer": {
      "definition_path": "striatum/rfc-0021-gold-set-review/roles/reviewer.md"
    },
    "ledger": {
      "definition_path": "striatum/rfc-0021-gold-set-review/roles/ledger.md"
    },
    "synthesizer": {
      "definition_path": "striatum/rfc-0021-gold-set-review/roles/synthesizer.md"
    },
    "coordinator": {
      "definition_path": "striatum/rfc-0021-gold-set-review/roles/coordinator.md"
    }
  },
