      "id": "review_claude",
      "type": "review",
      "title": "Review RFC 0025 with Claude",
      "role_id": "reviewer",
      "lane_id": "claude",
      "parallel_group": "independent_reviews",
      "fresh_session_required": true,
      "objective": "Review RFC 0025 for command taxonomy clarity, operator-safety coverage, backwards-compatibility risks, and whether fail-closed generic pipeline behavior is justified.",
      "task_prompt": {
        "path": "striatum/rfc-0025-command-names-review/prompts/review.md"
      },
      "inputs": [
        {
          "path": "docs/rfcs/0025-phase-scoped-command-names.md",
          "kind": "rfc_root"
        },
        {
          "path": "README.md",
          "kind": "operator_docs"
        },
        {
          "path": "Makefile",
          "kind": "command_surface"
        },
        {
          "path": "src/engram/cli.py",
          "kind": "command_surface"
        },
        {
          "path": "BUILD_PHASES.md",
          "kind": "phase_spec_root"
        },
        {
          "path": "DECISION_LOG.md",
          "kind": "decision_log"
        },
        {
          "path": "HUMAN_REQUIREMENTS.md",
          "kind": "principles"
        }
      ],
      "write_scope": {
        "mode": "review_only_artifact",
        "repo_write": false,
        "allowed_paths": [
          "docs/reviews/rfc0025/"
        ],
        "forbidden_paths": [
          ".striatum/",
          "docs/rfcs/",
          "BUILD_PHASES.md",
          "DECISION_LOG.md",
          "Makefile",
          "src/engram/"
        ]
      },
      "expected_artifacts": [
        {
          "logical_name": "review",
          "kind": "finding",
          "path": "docs/reviews/rfc0025/RFC_0025_COMMAND_NAMES_REVIEW_claude.md",
          "required": true
        }
      ]
    },
    {
      "id": "review_codex",
      "type": "review",
      "title": "Review RFC 0025 with Codex",
      "role_id": "reviewer",
      "lane_id": "codex",
      "parallel_group": "independent_reviews",
      "fresh_session_required": true,
      "objective": "Review RFC 0025 for implementation feasibility in argparse and Make, testability of fail-closed commands, migration sequencing, and script-compatibility risks.",
      "task_prompt": {
        "path": "striatum/rfc-0025-command-names-review/prompts/review.md"
