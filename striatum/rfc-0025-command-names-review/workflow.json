      "lane_id": "gemini",
      "parallel_group": "independent_reviews",
      "fresh_session_required": true,
      "objective": "Review RFC 0025 for operator ergonomics, naming clarity, deprecation messaging, and whether the proposed command surface prevents cross-phase mistakes.",
      "task_prompt": {
        "path": "striatum/rfc-0025-command-names-review/prompts/review.md"
