{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://engram.local/schemas/claim_grounding_response.v1.schema.json",
  "title": "Engram Claim Grounding Response",
  "description": "RFC 0053 response from a constrained grounding broker to claim extraction.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "const": "claim_grounding.response.v1"
    },
    "request_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": ["resolved", "ambiguous", "not_found", "denied", "deferred", "error"]
    },
    "mode": {
      "enum": ["local_lookup", "network_fetch"]
    },
    "network_fetch": {
      "enum": [
        "not_requested",
        "unsupported",
        "denied",
        "performed_by_grounding_broker"
      ]
    },
    "candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate"
      },
      "default": []
    },
    "omissions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/omission"
      },
      "default": []
    },
    "broker_version": {
      "type": "string",
      "minLength": 1
    },
    "dataset_snapshots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dataset_snapshot"
      },
      "default": []
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "schema_version",
    "request_id",
    "status",
    "mode",
    "network_fetch",
    "candidates",
    "omissions",
    "broker_version",
    "dataset_snapshots",
    "created_at"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "resolved"
          }
        }
      },
      "then": {
        "properties": {
          "candidates": {
            "minItems": 1,
            "maxItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "ambiguous"
          }
        }
      },
      "then": {
        "properties": {
          "candidates": {
            "minItems": 2
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "enum": ["not_found", "denied", "deferred", "error"]
          }
        }
      },
      "then": {
        "properties": {
          "candidates": {
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "network_fetch": {
            "const": "performed_by_grounding_broker"
          }
        }
      },
      "then": {
        "properties": {
          "mode": {
            "const": "network_fetch"
          }
        }
      }
    }
  ],
  "$defs": {
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "entity_kind": {
          "enum": [
            "person",
            "product",
            "place",
            "organization",
            "media_work",
            "tool",
            "concept",
            "unknown"
          ]
        },
        "canonical_label": {
          "type": "string",
          "minLength": 1
        },
        "external_ids": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/external_id"
          },
          "default": []
        },
        "grounding_evidence_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "minItems": 1
        },
        "source_url": {
          "type": ["string", "null"]
        },
        "source_label": {
          "type": ["string", "null"]
        },
        "content_hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "content_excerpt": {
          "type": "string",
          "minLength": 1,
          "maxLength": 500
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "stability": {
          "type": "string",
          "minLength": 1
        },
        "ambiguity_reasons": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "default": []
        }
      },
      "required": [
        "candidate_id",
        "entity_kind",
        "canonical_label",
        "external_ids",
        "grounding_evidence_ids",
        "content_hash",
        "content_excerpt",
        "confidence",
        "stability",
        "ambiguity_reasons"
      ]
    },
    "external_id": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["kind", "value"]
    },
    "omission": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": ["string", "null"]
        }
      },
      "required": ["reason"]
    },
    "dataset_snapshot": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dataset": {
          "type": "string",
          "minLength": 1
        },
        "snapshot_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": ["dataset", "snapshot_id"]
    }
  }
}
